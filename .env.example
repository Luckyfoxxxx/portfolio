# Database
DATABASE_URL="file:./data/portfolio.db"
# For production PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/portfolio"

# Auth
AUTH_SECRET="change-me-generate-with-openssl-rand-hex-32"

# Financial APIs
FINNHUB_API_KEY=""
ALPHA_VANTAGE_API_KEY=""

# Dev seed (db:seed-dev only — never committed with real values)
SEED_USERNAME="admin"
SEED_PASSWORD="your-dev-password-here"

# App
NODE_ENV="development"
PORT="3000"
